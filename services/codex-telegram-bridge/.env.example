# Codex Telegram Bridge
CODEX_TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# Human Telegram user IDs allowed to control the bot in DMs/groups.
ALLOWED_USER_IDS=
# Optional explicit human sender allowlist. Defaults to ALLOWED_USER_IDS.
ALLOWED_SENDER_IDS=
# Optional bot sender IDs allowed to use strict /handoff@TargetBot JSON in allowlisted groups.
ALLOWED_BOT_IDS=
# Optional group/supergroup IDs where the bridge accepts mentioned human messages and bot handoffs.
ALLOWED_CHAT_IDS=

# Codex runtime
CODEX_TIMEOUT=900
CODEX_MODEL=
CODEX_REASONING_EFFORT=high
# Use `danger-full-access` if you want Codex shell commands to have outbound internet
# and unrestricted local access. Keep `workspace-write` if you want sandboxed execution.
CODEX_SANDBOX=workspace-write
CODEX_SKIP_GIT_REPO_CHECK=true
CODEX_FULL_AUTO=false
CODEX_DANGEROUS_BYPASS=false
CODEX_ADD_DIRS=
CODEX_BRIDGE_PORT=8110

# Bridge state
CODEX_DEFAULT_FOLDER=${HOME}
CODEX_BRIDGE_STATE_DIR=${HOME}/.local/state/codex-telegram-bridge
CODEX_BRIDGE_LOG_FILE=${PWD}/logs/codex-telegram-bridge.log

# Watchdog
WATCHDOG_ENABLED=true
WATCHDOG_COMMAND_TIMEOUT=900
WATCHDOG_DEFAULT_TIMEOUT=180
WATCHDOG_STAGNATION_KILL=1800
