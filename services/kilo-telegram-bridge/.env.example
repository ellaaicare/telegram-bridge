# Kilo Code Telegram Bridge
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
KILOCODE_TELEGRAM_BOT_TOKEN=

# Human Telegram user IDs allowed to control the bot in DMs/groups.
ALLOWED_USER_IDS=
# Optional explicit human sender allowlist. Defaults to ALLOWED_USER_IDS.
ALLOWED_SENDER_IDS=
# Optional bot sender IDs allowed to use strict /handoff@TargetBot JSON in allowlisted groups.
ALLOWED_BOT_IDS=
# Optional group/supergroup IDs where the bridge accepts mentioned human messages and bot handoffs.
ALLOWED_CHAT_IDS=

# Harness identity
HARNESS_CLI=kilo
HARNESS_LABEL=Kilo Code
HARNESS_SERVICE_NAME=kilo-telegram-bridge
HARNESS_SESSION_BACKEND=bridge
HARNESS_AGENT=

# Runtime
CLAUDE_TIMEOUT=300
BRIDGE_MODEL=
BRIDGE_PORT=8130
BRIDGE_DEFAULT_FOLDER=${HOME}
BRIDGE_STATE_DIR=${HOME}/.local/state/kilo-telegram-bridge

# A2A bot handoff hardening
A2A_TRUST_REGISTRY_BOTS=true
A2A_PROGRESS_MODE=status
A2A_BOT_REGISTRY_PATH=

# Watchdog
WATCHDOG_ENABLED=false
WATCHDOG_BASH_TIMEOUT=300
WATCHDOG_SSH_TIMEOUT=900
WATCHDOG_TASK_TIMEOUT=600
WATCHDOG_DEFAULT_TIMEOUT=120
WATCHDOG_STAGNATION_KILL=1800
WATCHDOG_SESSION=watchdog-ops
WATCHDOG_EVAL_NODE=local

# Optional job dispatch. JSON object keyed by node name.
# Each node supports: ssh, claude, cwd.
# Use null for local ssh/cwd defaults.
DISPATCH_DEFAULT_NODE=local
DISPATCH_DEFAULT_REPO=
DISPATCH_NODES_JSON={"local":{"ssh":null,"claude":"claude","cwd":null}}
