[Unit]
Description=Claude Code Telegram Plugin (persistent interactive session for @PlatoDevBot)
After=network-online.target
Wants=network-online.target

[Service]
Type=forking
WorkingDirectory=%h
Environment=TERM=xterm-256color
Environment=TMUX_SESSION=claude-telegram
Environment=PLUGIN_START_DIR=%h
# Unset ANTHROPIC_API_KEY so Claude Code uses the claude.ai OAuth credential
# from ~/.claude/.credentials.json (subscription billing, not API billing).
Environment=ANTHROPIC_API_KEY=
ExecStart=%h/telegram-bridge/services/claude-telegram-bridge/systemd/claude-telegram-plugin-launch.sh
ExecStop=/usr/bin/tmux kill-session -t claude-telegram
Restart=on-failure
RestartSec=10
# Resource limits matching the existing bridge service
LimitNOFILE=65536

[Install]
WantedBy=default.target
